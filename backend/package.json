{
  "name": "backend",
  "version": "1.0.0",
  "description": "StellarID Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node --files src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node --files src/db/migrate.ts",
    "copy-vkeys": "mkdir -p circuits && cp ../zk-circuits/build/*_verification_key.json circuits/ 2>/dev/null || echo 'No vkeys to copy yet'",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@stellar/stellar-base": "^11.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.10.0",
    "@types/qr-image": "^3.2.10",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "qr-image": "^3.2.0",
    "redis": "^4.6.0",
    "snarkjs": "^0.7.4",
    "stellar-sdk": "^11.3.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0"
  }
}
